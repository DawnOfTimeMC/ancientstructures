{
    "schemaVersion": 1,
    "id": "${mod_id}",
    "version": "${version}",
    "name": "${mod_name}",
    "description": "${description}",
    "authors": [
        "${mod_author}"
    ],
    "contact": {
        "homepage": "https://github.com/DawnOfTimeMC/ancientstructures",
        "sources": "https://github.com/DawnOfTimeMC/ancientstructures"
    },
    "license": "${license}",
    "icon": "assets/modid/${mod_id}.png",
    "environment": "*",
    "entrypoints": {
        "main": [
            "org.dawnoftime.ancientstructures.AncientStructures"
        ]
    },
    "mixins": [
        "${mod_id}.mixins.json",
        "${mod_id}.fabric.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=0.14",
        "fabric": "*",
        "minecraft": "${minecraft_version}",
        "java": ">=17",
        "dawnoftimebuilder": ">=1.5.33",
        "armoroftheages": ">=1.3.8"
    },
    "suggests": {
        "fusion": "*"
    }
}
  